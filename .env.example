# ============================================================
# Bodega Palo Alto — Variables de entorno
# Copiar este archivo a .env.local y completar los valores.
# En Vercel: Project → Settings → Environment Variables
# ============================================================

# ----------------------------------------------------------
# REQUERIDAS EN PRODUCCIÓN
# ----------------------------------------------------------

# Identificador del cliente en el CMS.
# Debe coincidir con el slug configurado en el CMS.
NEXT_PUBLIC_CLIENT_SLUG=bodega-palo-alto

# URL base del CMS en producción.
# Ejemplo: https://cms.tuservidor.com/api/public/v1
NEXT_PUBLIC_API_URL=

# URL pública del sitio (sin trailing slash).
# Usada para generar sitemap.xml, open graph y HSTS.
# Ejemplo: https://bodegapaloalto.com
NEXT_PUBLIC_SITE_URL=

# Activar layout dinámico desde el CMS.
# true  → el contenido se carga desde NEXT_PUBLIC_API_URL
# false → se usan datos estáticos de fallback (lib/data.ts)
NEXT_PUBLIC_USE_CMS_LAYOUT=true

# ----------------------------------------------------------
# OPCIONALES
# ----------------------------------------------------------

# URL del CMS para el entorno de desarrollo.
# Si se omite, las llamadas usan el proxy local /api/public/v1.
# Ejemplo: http://localhost:4000/api/public/v1
NEXT_PUBLIC_API_DEV=

# Usar proxy interno de Next.js para el detalle de producto.
# true  → el servidor Next.js hace la llamada al CMS (más seguro en algunos entornos)
# false → el cliente llama directo a NEXT_PUBLIC_API_URL
NEXT_PUBLIC_USE_PROXY=false

# URL alternativa para la API de contacto (server-side únicamente, no expuesta al cliente).
# Solo necesaria si el endpoint de formularios está en un servidor distinto.
CONTACT_API_URL=
