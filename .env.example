# ============================================================
# Bodega Palo Alto — Variables de entorno
# Copiar este archivo a .env.local y completar los valores.
# En Vercel: Project → Settings → Environment Variables
# ============================================================

# ----------------------------------------------------------
# REQUERIDAS EN PRODUCCIÓN
# ----------------------------------------------------------

# Identificador del cliente en el CMS.
# Debe coincidir con el slug configurado en el CMS.
# Ejemplo: bodega-palo-alto
NEXT_PUBLIC_CLIENT_SLUG=

# URL base del CMS en producción.
# Ejemplo: https://micms.website/api/public/v1
# Opcional: si se omite, se usará el proxy local /api/public/v1
# Para staging, usar https://staging.micms.website/api/public/v1
NEXT_PUBLIC_API_URL=

# Activar layout dinámico desde el CMS.
# true  → el contenido se carga desde NEXT_PUBLIC_API_URL
# false → se usan datos estáticos de fallback (lib/data.ts)
# Ejemplo:
NEXT_PUBLIC_USE_CMS_LAYOUT=true

# ----------------------------------------------------------
# CACHE Y REVALIDACIÓN (opcional)
# ----------------------------------------------------------

# Secret compartido con el CMS para invalidar cache on-demand.
# Endpoint: POST /api/revalidate con header x-revalidate-secret
#   body: { "tag": ["cms-components"] } o { "path": "/es" }
# Si no se setea en producción, el endpoint rechazará todas las llamadas.
REVALIDATE_SECRET=

# TTL (segundos) de cache para cada endpoint. Por defecto son valores
# conservadores. Subirlos reduce Active CPU del CMS, bajarlos aumenta
# frescura. Combinar con invalidación on-demand vía /api/revalidate.
# CMS_REVALIDATE_SECONDS=300
# PRODUCTS_REVALIDATE_SECONDS=300
# PRODUCT_REVALIDATE_SECONDS=300
# ATTRIBUTE_CONFIG_REVALIDATE_SECONDS=3600

